# Project Environment Variables

## Backend Configuration
SPRING_APPLICATION_NAME=gs-tech-challenge
SERVER_PORT=8080
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_GS_TECHCHALLENGE=DEBUG

## Frontend Configuration
ANGULAR_APP_API_URL=http://localhost:8080
NODE_ENV=development

## External API Configuration
# Newton Analytics API endpoints
NEWTON_BETA_API_URL=https://api.newtonanalytics.com/stock-beta/
NEWTON_PORTFOLIO_API_URL=https://api.newtonanalytics.com/modern-portfolio/

## Application Settings
RISK_FREE_RATE=0.0425
DEFAULT_OBSERVATIONS=12
DEFAULT_PORTFOLIO_OBSERVATIONS=60
